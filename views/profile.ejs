```ejs
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Profile</title>

        <link
            href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
            rel="stylesheet" />

        <style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:linear-gradient(135deg,#0f172a,#1e293b,#334155);
    min-height:100vh;
    padding:40px;
}

.profile-container{
    max-width:900px;
    margin:auto;
    background:rgba(255,255,255,.08);
    backdrop-filter:blur(20px);
    border:1px solid rgba(255,255,255,.1);
    border-radius:25px;
    padding:40px;
    box-shadow:0 10px 30px rgba(0,0,0,.4);
}

.back-btn{
    width:50px;
    height:50px;
    border:none;
    border-radius:50%;
    background:white;
    cursor:pointer;
    font-size:24px;
    transition:.3s;
}

.back-btn:hover{
    transform:scale(1.1);
}

.profile-top{
    text-align:center;
    margin-top:20px;
}

.profile-icon{
    width:110px;
    height:110px;
    margin:auto;
    background:#3b82f6;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:55px;
    color:white;
}

.profile-top h1{
    color:white;
    margin-top:20px;
}

.email{
    color:#cbd5e1;
    margin-top:10px;
}

.section-title{
    color:white;
    margin-top:50px;
    margin-bottom:20px;
}

.booking-card{
    background:white;
    border-radius:20px;
    padding:25px;
    margin-bottom:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.15);
    transition:.3s;
}

.booking-card:hover{
    transform:translateY(-5px);
}

.car-name{
    font-size:22px;
    font-weight:700;
    margin-bottom:15px;
}

.info{
    margin-bottom:10px;
    color:#444;
}

.status{
    display:inline-block;
    background:#22c55e;
    color:white;
    padding:8px 18px;
    border-radius:20px;
    margin-top:10px;
}

.cancel-btn{
    margin-top:20px;
    border:none;
    background:#ef4444;
    color:white;
    padding:12px 25px;
    border-radius:12px;
    cursor:pointer;
    transition:.3s;
}

.cancel-btn:hover{
    background:#dc2626;
}

.logout-btn{
    display:block;
    width:180px;
    margin:40px auto 0;
    text-align:center;
    text-decoration:none;
    background:black;
    color:white;
    padding:15px;
    border-radius:15px;
    transition:.3s;
}

.logout-btn:hover{
    background:#111827;
}

.empty{
    color:white;
    text-align:center;
    margin-top:20px;
    font-size:18px;
}

@media(max-width:768px){
    .profile-container{
        padding:20px;
    }
}
</style>
    </head>
    <body>

        <% if (typeof message !== 'undefined' && message) { %>
        <script>
alert("<%= message %>");
</script>
        <% } %>

        <div class="profile-container">

            <button class="back-btn" onclick="window.location.href='/'">
                <i class="ri-arrow-left-line"></i>
            </button>

            <div class="profile-top">

                <div class="profile-icon">
                    <i class="ri-user-3-line"></i>
                </div>

                <h1>Welcome, <%= user.username %></h1>

                <p class="email">
                    <i class="ri-mail-line"></i>
                    <%= user.email %>
                </p>

            </div>

            <h2 class="section-title">
                <i class="ri-car-line"></i>
                Your Bookings
            </h2>

            <% if(userBookings && userBookings.length > 0){ %>

            <% userBookings.forEach(function(b){ %>

            <div class="booking-card">

                <div class="car-name">
                    🚗 <%= b.carName %>
                </div>

                <div class="info">
                    <b>Delivery Type:</b>
                    <%= b.deliveryType %>
                </div>

                <div class="info">
                    <b>Pickup Date:</b>
                    <%= b.pickingDate.toDateString() %>
                </div>

                <div class="info">
                    <b>Drop Date:</b>
                    <%= b.droppingDate.toDateString() %>
                </div>

                <span class="status">
                    <%= b.status %>
                </span>

                <br>

                <button class="cancel-btn" data-id="<%= b._id %>">
                    Cancel Booking
                </button>

            </div>

            <% }) %>

            <% } else { %>

            <div class="empty">
                No bookings available 🚗
            </div>

            <% } %>

            <a href="/logout" class="logout-btn">
                <i class="ri-logout-box-r-line"></i>
                Logout
            </a>

        </div>

        <script>

async function cancelBooking(id){

if(!confirm("Are you sure you want to cancel this booking?")){
return;
}

try{

const res=await fetch(`/bookings/cancel-booking/${id}`,{
method:"DELETE"
});

const data=await res.json();

alert(data.message);

location.reload();

}
catch(err){

alert("Server Error");

}

}

document.querySelectorAll(".cancel-btn").forEach(btn=>{

btn.addEventListener("click",()=>{

const bookingId=btn.dataset.id;

cancelBooking(bookingId);

});

});

</script>

    </body>
</html>
```
