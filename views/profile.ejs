<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f4f6fb;
            margin: 0;
            padding: 0;
        }
        .profile-container {
            max-width: 400px;
            margin: 60px auto;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 32px 24px;
            text-align: center;
        }
        .profile-icon {
            font-size: 64px;
            color: #4f8ef7;
            margin-bottom: 16px;
        }
        h1 {
            margin: 0 0 12px 0;
            font-size: 2em;
            color: #333;
        }
        p {
            color: #555;
            margin: 8px 0;
        }
        .bookings-list {
            margin-top: 32px;
            text-align: left;
        }
        .bookings-list h2 {
            color: #4f8ef7;
            font-size: 1.2em;
            margin-bottom: 12px;
        }
        .bookings-list ul {
            list-style: none;
            padding: 0;
        }
        .bookings-list li {
            background: #f4f6fb;
            margin-bottom: 10px;
            padding: 12px;
            border-radius: 8px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }
        .status {
            font-weight: bold;
            color: #357ae8;
        }
        a {
            display: inline-block;
            margin-top: 24px;
            padding: 10px 24px;
            background: #4f8ef7;
            color: #fff;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
            transition: background 0.2s;
        }
        a:hover {
            background: #357ae8;
        }
    </style>
    <!-- Remix Icon CDN for user icon -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
</head>
<body>
    <% if (typeof message !== 'undefined' && message) { %>
      <script>
        alert("<%= message %>");
      </script>
    <% } %>
    <div class="profile-container">
        <div class="profile-icon">
            <i class="ri-user-line"></i>
        </div>
        <h1>Welcome, <%= user.username %>!</h1>
        <p>Email: <%= user.email %></p>
        <div class="bookings-list">
            <h2>Your Bookings</h2>
            <ul>
                <% if (userBookings && userBookings.length > 0) { %>
                    <% userBookings.forEach(function(b) { %>
                        <li>
                            <strong>Car:</strong> <%= b.carName %><br>
                            <strong>Delivery Type:</strong> <%= b.deliveryType %><br>
                            <strong>Picking Date:</strong> <%= b.pickingDate.toDateString() %><br>
                            <strong>Dropping Date:</strong> <%= b.droppingDate.toDateString() %><br>
                            <span class="status"><%= b.status %></span>

                        <button class="cancel-btn" data-id="<%= b._id %>">Cancel Car</button>
                        
                        
<script>
